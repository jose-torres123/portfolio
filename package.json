{
  "name": "portfolio",
  "version": "1.0.2",
  "description": "Portfolio + CMS built with React, Vite, Supabase, and Turborepo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build --concurrency=10",
    "type-check": "turbo run type-check --concurrency=10",
    "lint": "turbo run lint --concurrency=10",
    "format": "turbo run format --concurrency=10",
    "test": "turbo run test --concurrency=10",
    "quality": "turbo run type-check lint test --concurrency=10",
    "db:types": "turbo run db:types",
    "db:migrate": "turbo run db:migrate",
    "db:reset": "turbo run db:reset",
    "db:start": "turbo run db:start"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^20.11.0",
    "supabase": "^2.84.10",
    "turbo": "^1.13.0",
    "typescript": "^5.3.0"
  }
}
