# ═══════════════════════════════════════
# Variables de Entorno — Monorepo
# Copiar a .env y rellenar valores reales
# ═══════════════════════════════════════

# ── Supabase (frontend — VITE_ prefix expone al browser) ──
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Supabase (backend/CI — NUNCA exponer en frontend) ──
# SUPABASE_SERVICE_ROLE_KEY=  ← SOLO para edge functions o scripts server-side
# SUPABASE_DB_PASSWORD=       ← SOLO para CI/CD (GitHub Secrets)

# ── App Config ──
VITE_APP_NAME=MiApp
VITE_APP_URL=http://localhost:5173

# ── Claude Code (configuración local del agente) ──
# Aumentar límite de tokens de output para evitar truncamiento en tareas grandes
# Setear en tu shell profile (~/.zshrc o ~/.bashrc):
# export CLAUDE_CODE_MAX_OUTPUT_TOKENS=64000
